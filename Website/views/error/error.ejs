<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof title !== 'undefined' ? title : 'Error' %> | Business Incubator</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="/css/style.css" rel="stylesheet" />
  </head>
  <body class="bg-gray-100 min-h-screen flex flex-col font-sans">
     <%- include('../partials/header') %>
    <main class="flex-grow flex items-center justify-center p-6 relative overflow-hidden">
      
      <div class="absolute top-20 left-10 w-32 h-32 rounded-full bg-brand-yellow blur-3xl opacity-30 animate-pulse"></div>
      <div class="absolute bottom-20 right-10 w-40 h-40 rounded-full bg-brand-pink blur-3xl opacity-30 animate-pulse"></div>

      <div class="relative bg-neo-white border-4 border-neo-black shadow-neo p-10 max-w-lg w-full text-center rounded-xl transform transition hover:-translate-y-1 hover:shadow-neo-hover duration-300">
        
        <div class="w-24 h-24 mx-auto mb-6 rounded-full border-4 border-neo-black shadow-neo-sm flex items-center justify-center text-4xl" style="background-color: <%= typeof color !== 'undefined' ? color : '#e38524' %>;">
          <i class="<%= typeof icon !== 'undefined' ? icon : 'fa-solid fa-triangle-exclamation' %> text-neo-black"></i>
        </div>

        <h1 class="font-display text-8xl font-bold text-neo-black mb-2 tracking-tighter">
          <%= typeof statusCode !== 'undefined' ? statusCode : '500' %>
        </h1>

        <h2 class="font-display text-2xl font-bold text-gray-800 mb-4 uppercase tracking-wide">
          <%= typeof title !== 'undefined' ? title : 'Server Error' %>
        </h2>

        <p class="font-sans text-gray-600 mb-8 text-lg leading-relaxed">
          <%= typeof message !== 'undefined' ? message : 'Something went wrong.' %>
        </p>

        <a href="<%= typeof redirectLink !== 'undefined' ? redirectLink : '/' %>" class="inline-block px-8 py-3 bg-neo-black text-white font-display font-bold text-lg rounded-lg border-2 border-transparent hover:bg-white hover:text-neo-black hover:border-neo-black transition-all duration-300 shadow-neo-sm hover:shadow-none">
          <%= typeof buttonText !== 'undefined' ? buttonText : 'Go Home' %> <i class="fa-solid fa-arrow-right ml-2"></i>
        </a>
      </div>

    </main>

      <%- include('../partials/footer') %>
  </body>
</html>