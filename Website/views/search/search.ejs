<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head.ejs') %>

<body class="bg-[#FFFDF5] text-black min-h-screen flex flex-col font-sans">
    <%- include('../partials/header.ejs') %>

    <main class="flex-1 px-6 py-10">
        <div class="max-w-4xl mx-auto">
            
            <!-- Page Header -->
            <div class="mb-10 text-center md:text-left">
                <span class="bg-black text-white px-3 py-1 font-bold text-sm uppercase tracking-wider mb-2 inline-block transform -rotate-1">
                    Global Engine
                </span>
                <h1 class="text-5xl md:text-6xl font-black text-black mb-2 uppercase tracking-tighter">
                    Global <span class="bg-[#f59e0b] text-black px-2 border-4 border-black shadow-[4px_4px_0px_0px_#000] italic inline-block transform rotate-1">Search</span>
                </h1>
                <p class="text-slate-650 font-bold uppercase text-xs tracking-wider">Search projects, mentors, and workshops across the platform</p>
            </div>

            <!-- Search Form -->
            <form action="/v1/search" method="GET" class="bg-white border-4 border-black p-6 md:p-8 shadow-[6px_6px_0px_0px_#000] mb-10">
                <div class="flex flex-col md:flex-row gap-4 mb-6">
                    <div class="flex-1 relative">
                        <input 
                            type="text" 
                            name="q" 
                            value="<%= q %>" 
                            placeholder="Type keywords (e.g. Tech, FinTech, UI/UX, AI)..." 
                            class="w-full px-4 py-4 border-4 border-black bg-[#FFFDF5] font-black text-lg focus:outline-none focus:bg-white focus:shadow-[4px_4px_0px_0px_#000] transition-all"
                            required
                        />
                    </div>
                    <button 
                        type="submit" 
                        class="bg-[#4f46e5] text-white px-8 py-4 font-black uppercase text-lg border-4 border-black shadow-[4px_4px_0px_0px_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all flex items-center justify-center gap-2"
                    >
                        <span>🔍</span> Search
                    </button>
                </div>

                <!-- Entity Filters -->
                <div class="border-t-4 border-black pt-4">
                    <span class="block text-xs font-black uppercase tracking-widest text-gray-500 mb-3">Filter by Entity Type:</span>
                    <div class="flex flex-wrap gap-4">
                        <label class="flex items-center gap-2 cursor-pointer select-none">
                            <input 
                                type="checkbox" 
                                name="type" 
                                value="projects" 
                                <%= types.projects ? 'checked' : '' %>
                                class="w-5 h-5 accent-black border-2 border-black"
                            />
                            <span class="font-black uppercase text-sm">🚀 Projects</span>
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer select-none">
                            <input 
                                type="checkbox" 
                                name="type" 
                                value="mentors" 
                                <%= types.mentors ? 'checked' : '' %>
                                class="w-5 h-5 accent-black border-2 border-black"
                            />
                            <span class="font-black uppercase text-sm">🧑‍🏫 Mentors</span>
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer select-none">
                            <input 
                                type="checkbox" 
                                name="type" 
                                value="workshops" 
                                <%= types.workshops ? 'checked' : '' %>
                                class="w-5 h-5 accent-black border-2 border-black"
                            />
                            <span class="font-black uppercase text-sm">🎓 Workshops</span>
                        </label>
                    </div>
                </div>
            </form>

            <!-- Search Results -->
            <% if (q.length > 0) { %>
                <div class="mb-6">
                    <h2 class="text-2xl font-black uppercase tracking-tight">
                        Results for "<span class="text-[#4f46e5]"><%= q %></span>" (<%= results.length %>)
                    </h2>
                </div>

                <% if (results.length > 0) { %>
                    <div class="space-y-6">
                        <% results.forEach(item => { %>
                            <div class="bg-white border-4 border-black p-6 shadow-[6px_6px_0px_0px_#000] hover:-translate-y-1 transition-all flex flex-col md:flex-row gap-4 justify-between items-start md:items-center">
                                <div class="flex items-start gap-4">
                                    <!-- Unified Icon -->
                                    <div class="text-4xl bg-gray-100 border-2 border-black p-2 rounded shadow-[2px_2px_0px_0px_#000] flex-shrink-0">
                                        <%= item.icon %>
                                    </div>
                                    <div>
                                        <div class="flex flex-wrap items-center gap-2 mb-1">
                                            <span class="bg-black text-white text-[9px] font-black px-2 py-0.5 border border-black uppercase tracking-wider">
                                                <%= item.typeName %>
                                            </span>
                                            <span class="bg-[#FFFDF5] text-black border-2 border-black text-[9px] font-black px-2 py-0.5 uppercase">
                                                <%= item.badge %>
                                            </span>
                                        </div>
                                        <h3 class="text-xl font-black uppercase text-black mb-1"><%= item.title %></h3>
                                        <p class="text-xs font-bold text-slate-500 uppercase mb-2"><%= item.subtitle %></p>
                                        <p class="text-sm font-medium text-slate-700 italic"><%= item.description.length > 180 ? item.description.slice(0, 180) + '...' : item.description %></p>
                                    </div>
                                </div>
                                <div class="w-full md:w-auto pt-4 md:pt-0 border-t-2 md:border-t-0 border-slate-100 flex-shrink-0">
                                    <a 
                                        href="<%= item.link %>" 
                                        class="bg-black text-white px-5 py-2.5 text-xs font-black uppercase border-2 border-black shadow-[2px_2px_0px_0px_#f59e0b] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-none transition-all block text-center"
                                    >
                                        View details →
                                    </a>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="bg-white border-4 border-black p-12 text-center shadow-[6px_6px_0px_0px_#000]">
                        <div class="text-6xl mb-4 grayscale">🔍</div>
                        <h3 class="text-2xl font-black uppercase text-slate-700">No results found</h3>
                        <p class="text-slate-500 font-bold text-sm mt-2">We couldn't find any matches. Try refactoring your keyword or checking the filter options.</p>
                    </div>
                <% } %>
            <% } else { %>
                <!-- Empty Search Prompt -->
                <div class="bg-white border-4 border-black p-12 text-center shadow-[6px_6px_0px_0px_#000]">
                    <div class="text-6xl mb-4">💡</div>
                    <h3 class="text-2xl font-black uppercase text-slate-700">Awaiting your search query...</h3>
                    <p class="text-slate-500 font-bold text-sm mt-2">Enter keywords in the box above to perform a global search query across the platform.</p>
                </div>
            <% } %>

        </div>
    </main>

    <%- include('../partials/footer.ejs') %>
</body>
</html>
