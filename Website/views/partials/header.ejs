<header class="py-4 shadow bg-brand-slate text-white" x-data="{ open: false, isLoggedIn: <%= user ? 'true' : 'false' %> }">
  <div
    class="container mx-auto flex flex-col md:flex-row justify-between items-center px-4 gap-4 md:gap-0 overflow-auto whitespace-nowrap"
  >
    <div class="flex w-full justify-between items-center whitespace-nowrap">
      <div class="flex items-center gap-2 sm:gap-3">
        <a href="/" rel="noopener noreferrer">
          <img
            src="/assets/images/logo.jpg"
            alt="Business Incubator Platform logo"
            class="h-8 w-8 sm:h-9 sm:w-9 md:h-10 md:w-10 rounded-full object-cover border border-white shadow-lg bg-black"
            loading="eager"
            decoding="async"
          />
        </a>
        <a href="/" class="text-base xs:text-lg sm:text-xl md:text-2xl font-bold text-center md:text-left whitespace-nowrap leading-tight">
          Business Incubator Platform
        </a>
      </div>

      <!-- Hamburger button -->
      <button
        class="md:hidden flex items-center px-3 py-2"
        @click="open = !open"
        aria-label="Toggle menu"
      >
        <svg
          class="w-8 h-8"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"
          ></path>
        </svg>
      </button>
    </div>

    <!-- Menu: hidden on md+, shown on mobile/tablet when open -->
    <div
      :class="open ? 'flex' : 'hidden'"
      class="flex-col w-full mt-4 md:mt-0 md:flex md:flex-row md:items-center md:justify-center md:w-auto md:gap-0 gap-4 whitespace-nowrap"
    >
      <nav
        class="w-full md:w-auto flex flex-col md:flex-row flex-1 md:justify-center items-center md:items-center gap-4 md:gap-0 whitespace-nowrap"
      >
        <ul
          class="flex flex-col md:flex-row w-full md:w-auto items-center md:space-x-8 space-y-2 md:space-y-0 whitespace-nowrap"
        >
          <li>
            <a href="/v1/projects" class="hover:underline whitespace-nowrap" @click="open = false">
              Projects & Ideas
            </a>
          </li>
          <li>
            <a href="/v1/mentors" class="hover:underline whitespace-nowrap" @click="open = false">
              Mentors
            </a>
          </li>
          <li>
            <a href="/v1/workshop" class="hover:underline whitespace-nowrap" @click="open = false">
              Workshops
            </a>
          </li>
          <li>
            <a href="/v1/search" class="hover:underline whitespace-nowrap" @click="open = false">
              🔍 Search
            </a>
          </li>
          <li>
            <a href="/v1/about" class="bg-white text-black px-4 py-2 rounded-full font-semibold hover:bg-gray-100 transition whitespace-nowrap" @click="open = false">
              About
            </a>
          </li>
        </ul>
      </nav>
      
      <!-- Auth buttons: Show Login/Signup if NOT logged in -->
      <div
        x-show="!isLoggedIn"
        class="flex flex-col md:flex-row items-center gap-2 w-full md:w-auto justify-center md:justify-end mt-2 md:mt-0 whitespace-nowrap"
      >
        <a href="/v1/auth/login" class="px-4 py-2 hover:underline whitespace-nowrap" @click="open = false">
          Log in
        </a>
        <a href="/v1/auth/signup" class="px-4 py-2 rounded w-full md:w-auto text-center whitespace-nowrap" style="font-weight: 600;" @click="open = false">
          Sign up
        </a>
      </div>

      <!-- Logout button: Show if logged in -->
      <div
        x-show="isLoggedIn"
        x-cloak
        class="flex flex-col md:flex-row items-center gap-2 w-full md:w-auto justify-center md:justify-end mt-2 md:mt-0 whitespace-nowrap"
      >
        <a href="/v1/auth/profile" class="px-4 py-2 hover:underline whitespace-nowrap" @click="open = false">
          Profile
        </a>
        <button
          @click="handleLogout()"
          class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded w-full md:w-auto text-center whitespace-nowrap transition"
          style="font-weight: 600;"
        >
          Logout
        </button>
      </div>
    </div>
  </div>
  
  <!-- CDN for menu toggle -->
  <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
  
  <style>
    [x-cloak] { display: none !important; }
  </style>
  
  <script>
    async function handleLogout() {
      try {
        const response = await fetch('/v1/auth/logout', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          credentials: 'include'
        });

        if (response.ok) {
          localStorage.setItem('isLoggedIn', 'false');
          window.location.href = '/v1/auth/login';
        } else {
          alert('Failed to logout. Please try again.');
        }
      } catch (error) {
        console.error('Logout error:', error);
        alert('An error occurred during logout.');
      }
    }
  </script>
</header>