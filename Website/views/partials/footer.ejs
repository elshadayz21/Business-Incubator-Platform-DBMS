<% const SocialLinks = {
  twitter: "https://twitter.com",
  youtube: "https://youtube.com",
  instagram: "https://instagram.com",
  facebook: "https://facebook.com",
  pinterest: "https://pinterest.com"
}; %>

<footer class="bg-brand-slate text-white pt-20 pb-10 px-4 border-t-4 border-black">
  <div class="max-w-7xl mx-auto flex flex-col gap-16">
    <div class="flex flex-col lg:flex-row gap-12 w-full justify-between">
      
      <div class="flex-1 max-w-2xl text-left">
        <h2 class="text-3xl md:text-5xl font-bold mb-8 leading-tight font-display uppercase tracking-tighter">
          Subscribe to get <span class="text-brand-indigo">tips & tactics</span> to grow.
        </h2>
        <form class="flex w-full max-w-xl group">
          <input
            type="email"
            placeholder="YOUR EMAIL ADDRESS"
            class="flex-1 px-6 py-4 border-4 border-black bg-white text-black font-bold focus:outline-none placeholder-slate-400"
          />
          <button
            type="submit"
            class="px-8 py-4 border-4 border-l-0 border-black bg-brand-indigo text-white font-black text-2xl hover:bg-white hover:text-black transition-all shadow-neo-sm"
          >
            →
          </button>
        </form>
      </div>

      <div class="flex flex-wrap gap-12 lg:gap-24 uppercase font-display font-bold">
        <div class="flex flex-col gap-3 min-w-[150px]">
            <span class="text-brand-amber text-xs tracking-widest mb-2">Platform</span>
            <a href="#" class="hover:text-brand-indigo transition-colors">Discover</a>
            <a href="#" class="hover:text-brand-indigo transition-colors">Blog</a>
            <a href="#" class="hover:text-brand-indigo transition-colors">Pricing</a>
            <a href="#" class="hover:text-brand-indigo transition-colors">Small Bets</a>
        </div>
        <div class="flex flex-col gap-3 min-w-[150px]">
            <span class="text-brand-amber text-xs tracking-widest mb-2"> Legal</span>
            <a href="#" class="hover:text-brand-indigo transition-colors">Help</a>
            <a href="#" class="hover:text-brand-indigo transition-colors">Terms</a>
            <a href="#" class="hover:text-brand-indigo transition-colors">Privacy</a>
        </div>
      </div>
    </div>

    <div class="flex flex-col md:group md:flex-row justify-between items-center pt-8 border-t-4 border-black/30 gap-8">
      <div class="flex items-center gap-4 flex-col md:flex-row">
        <img src="/assets/images/dxvalley-logo.jpg" alt="DxValley Logo" class="h-12 md:h-16 bg-white p-2 border-4 border-black shadow-neo-sm object-contain hover:scale-105 transition-transform cursor-pointer" loading="lazy" />
        <span class="font-bold text-slate-400 font-sans italic text-center md:text-left">
          © <%= new Date().getFullYear() %> DxVALLEY INCUBATION. BUILT FOR BUILDERS.
        </span>
      </div>
      
      <div class="flex gap-6">
        <% Object.entries(SocialLinks).forEach(([platform, url]) => { %>
          <a href="<%= url %>" target="_blank" rel="noopener noreferrer" 
             class="w-12 h-12 flex items-center justify-center border-4 border-black bg-white text-black shadow-neo-sm hover:translate-y-1 hover:shadow-none transition-all">
            <i class="fa-brands fa-<%= platform %> text-xl"></i>
          </a>
        <% }); %>
      </div>
    </div>
  </div>
</footer>