<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head.ejs') %>

<body class="bg-[#FFFDF5] text-black min-h-screen flex flex-col font-sans">
    <%- include('../partials/header.ejs') %>

    <main class="flex-1 px-6 py-10">
        <div class="max-w-7xl mx-auto">
            
            <div class="mb-10">
                <span class="bg-black text-white px-3 py-1 font-bold text-sm uppercase tracking-wider mb-2 inline-block transform -rotate-1">
                    User Settings
                </span>
                <h1 class="text-5xl md:text-6xl font-black text-black mb-2 uppercase tracking-tighter">
                    Your <span class="bg-[#4f46e5] text-white px-2 border-4 border-black shadow-[4px_4px_0px_0px_#000] italic inline-block transform rotate-1">Profile</span>
                </h1>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

                <aside class="lg:col-span-3">
                    <div class="bg-white border-4 border-black p-6 sticky top-6 shadow-[6px_6px_0px_0px_#000]">
                        <nav class="space-y-4">
                            <!-- Tab: Profile Info (All) -->
                            <a href="?tab=info"
                                class="flex items-center gap-3 px-4 py-3 border-2 border-black <%= dashboard.activeTab === 'info' ? 'bg-[#4f46e5] text-white shadow-none' : 'bg-white text-black hover:-translate-y-1 hover:shadow-[3px_3px_0px_0px_#000]' %> font-black uppercase transition-all">
                                <span>🆔 Profile Info</span>
                            </a>

                            <% if (user.role === 'entrepreneur') { %>
                                <!-- Tab: My Projects (Entrepreneur) -->
                                <a href="?tab=projects"
                                    class="flex items-center gap-3 px-4 py-3 border-2 border-black <%= dashboard.activeTab === 'projects' ? 'bg-[#4f46e5] text-white shadow-none' : 'bg-white text-black hover:-translate-y-1 hover:shadow-[3px_3px_0px_0px_#000]' %> font-black uppercase transition-all">
                                    <span>🚀 My Projects (<%= dashboard.projects.length %>)</span>
                                </a>
                                <!-- Tab: Funding Requests (Entrepreneur) -->
                                <a href="?tab=funding"
                                    class="flex items-center gap-3 px-4 py-3 border-2 border-black <%= dashboard.activeTab === 'funding' ? 'bg-[#4f46e5] text-white shadow-none' : 'bg-white text-black hover:-translate-y-1 hover:shadow-[3px_3px_0px_0px_#000]' %> font-black uppercase transition-all">
                                    <span>💵 Funding Requests (<%= dashboard.fundingRequests.length %>)</span>
                                </a>
                                <!-- Tab: Enrolled Workshops (Entrepreneur) -->
                                <a href="?tab=workshops"
                                    class="flex items-center gap-3 px-4 py-3 border-2 border-black <%= dashboard.activeTab === 'workshops' ? 'bg-[#4f46e5] text-white shadow-none' : 'bg-white text-black hover:-translate-y-1 hover:shadow-[3px_3px_0px_0px_#000]' %> font-black uppercase transition-all">
                                    <span>🎓 My Workshops (<%= dashboard.workshops.length %>)</span>
                                </a>
                                <!-- Tab: Notifications (Entrepreneur) -->
                                <% let unreadCount = dashboard.notifications.filter(n => !n.read).length; %>
                                <a href="?tab=notifications"
                                    class="flex items-center justify-between px-4 py-3 border-2 border-black <%= dashboard.activeTab === 'notifications' ? 'bg-[#4f46e5] text-white shadow-none' : 'bg-white text-black hover:-translate-y-1 hover:shadow-[3px_3px_0px_0px_#000]' %> font-black uppercase transition-all">
                                    <div class="flex items-center gap-3">
                                        <span>🔔 Notifications</span>
                                    </div>
                                    <% if (unreadCount > 0) { %>
                                        <span class="bg-red-500 text-white text-xs px-2 py-0.5 border-2 border-black rounded-full shadow-[1px_1px_0_0_#000]"><%= unreadCount %></span>
                                    <% } %>
                                </a>
                            <% } else if (user.role === 'mentor') { %>
                                <!-- Tab: Assigned Projects (Mentor) -->
                                <a href="?tab=projects"
                                    class="flex items-center gap-3 px-4 py-3 border-2 border-black <%= dashboard.activeTab === 'projects' ? 'bg-[#4f46e5] text-white shadow-none' : 'bg-white text-black hover:-translate-y-1 hover:shadow-[3px_3px_0px_0px_#000]' %> font-black uppercase transition-all">
                                    <span>🛠️ Assigned Projects (<%= dashboard.projects.length %>)</span>
                                </a>
                                <!-- Tab: Workshops Led (Mentor) -->
                                <a href="?tab=workshops"
                                    class="flex items-center gap-3 px-4 py-3 border-2 border-black <%= dashboard.activeTab === 'workshops' ? 'bg-[#4f46e5] text-white shadow-none' : 'bg-white text-black hover:-translate-y-1 hover:shadow-[3px_3px_0px_0px_#000]' %> font-black uppercase transition-all">
                                    <span>🧑‍🏫 Workshops Led (<%= dashboard.workshops.length %>)</span>
                                </a>
                            <% } else if (user.role === 'investor') { %>
                                <!-- Tab: Pending Funding (Investor) -->
                                <a href="?tab=funding"
                                    class="flex items-center gap-3 px-4 py-3 border-2 border-black <%= dashboard.activeTab === 'funding' ? 'bg-[#4f46e5] text-white shadow-none' : 'bg-white text-black hover:-translate-y-1 hover:shadow-[3px_3px_0px_0px_#000]' %> font-black uppercase transition-all">
                                    <span>📥 Pending Funding (<%= dashboard.pendingRequests.length %>)</span>
                                </a>
                                <!-- Tab: Portfolio (Investor) -->
                                <a href="?tab=portfolio"
                                    class="flex items-center gap-3 px-4 py-3 border-2 border-black <%= dashboard.activeTab === 'portfolio' ? 'bg-[#4f46e5] text-white shadow-none' : 'bg-white text-black hover:-translate-y-1 hover:shadow-[3px_3px_0px_0px_#000]' %> font-black uppercase transition-all">
                                    <span>💼 My Portfolio (<%= dashboard.portfolio.length %>)</span>
                                </a>
                            <% } %>

                            <!-- Tab: Activity Timeline (All) -->
                            <a href="?tab=timeline"
                                class="flex items-center gap-3 px-4 py-3 border-2 border-black <%= dashboard.activeTab === 'timeline' ? 'bg-[#4f46e5] text-white shadow-none' : 'bg-white text-black hover:-translate-y-1 hover:shadow-[3px_3px_0px_0px_#000]' %> font-black uppercase transition-all">
                                <span>📜 Activity Timeline</span>
                            </a>
                            <!-- Tab: Platform Stats (All) -->
                            <a href="?tab=stats"
                                class="flex items-center gap-3 px-4 py-3 border-2 border-black <%= dashboard.activeTab === 'stats' ? 'bg-[#4f46e5] text-white shadow-none' : 'bg-white text-black hover:-translate-y-1 hover:shadow-[3px_3px_0px_0px_#000]' %> font-black uppercase transition-all">
                                <span>📊 Platform Stats</span>
                            </a>
                        </nav>
                    </div>
                </aside>

                <div class="lg:col-span-9 space-y-8">

                    <% if (error) { %>
                        <div class="bg-red-100 border-4 border-red-500 p-4 flex items-center gap-4 shadow-[4px_4px_0_0_#ef4444]">
                            <div class="flex-shrink-0">⚠️</div>
                            <div>
                                <h3 class="text-red-700 font-black uppercase text-lg">Error</h3>
                                <p class="text-red-600 font-bold"><%= error %></p>
                            </div>
                        </div>
                    <% } %>

                    <% if (success) { %>
                        <div class="bg-green-100 border-4 border-green-500 p-4 flex items-center gap-4 shadow-[4px_4px_0_0_#22c55e]">
                            <div class="flex-shrink-0">✅</div>
                            <div>
                                <h3 class="text-green-700 font-black uppercase text-lg">Success</h3>
                                <p class="text-green-600 font-bold"><%= success %></p>
                            </div>
                        </div>
                    <% } %>

                    <!-- Active Tab Content -->
                    <% if (dashboard.activeTab === 'info') { %>
                        <!-- PROFILE SETTINGS TAB -->
                        <section id="profile-picture" class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000] text-left">
                            <div class="flex items-center gap-3 mb-8 border-b-4 border-black pb-2 w-fit">
                                <span class="bg-[#f59e0b] p-2 border-2 border-black text-black">📸</span>
                                <h2 class="text-2xl font-black uppercase tracking-tight">Avatar Settings</h2>
                            </div>

                            <div class="flex flex-col sm:flex-row items-center gap-8">
                                <div class="relative">
                                    <% if (user && user.profilePicture) { %>
                                        <img src="<%= user.profilePicture %>?v=<%= Date.now() %>" alt="Profile"
                                            class="w-40 h-40 object-cover border-4 border-black shadow-[4px_4px_0_0_#000]">
                                    <% } else { %>
                                        <div class="w-40 h-40 bg-[#f59e0b] border-4 border-black flex items-center justify-center shadow-[4px_4px_0_0_#000]">
                                            <span class="text-6xl font-black text-black"><%= user && user.name ? user.name.charAt(0).toUpperCase() : '?' %></span>
                                        </div>
                                    <% } %>
                                </div>

                                <div class="flex-1 w-full">
                                    <form action="/v1/auth/profile/upload-picture" method="POST" enctype="multipart/form-data" class="space-y-4">
                                        <label class="block text-xs font-black uppercase mb-2 tracking-widest text-gray-500">New Picture</label>
                                        <input name="profilePicture" type="file" accept="image/*" required
                                            class="w-full p-2 border-2 border-black bg-[#FFFDF5] font-bold file:mr-4 file:py-2 file:px-4 file:border-2 file:border-black file:bg-[#f59e0b] file:text-black file:font-black file:uppercase hover:file:bg-black hover:file:text-white transition-all" />
                                        
                                        <button type="submit" class="bg-black text-white px-6 py-3 font-black uppercase border-2 border-black shadow-[4px_4px_0_0_#4f46e5] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all">
                                            Update Avatar
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </section>

                        <section id="profile-info" class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000] text-left">
                            <div class="flex items-center gap-3 mb-8 border-b-4 border-black pb-2 w-fit">
                                <span class="bg-[#4f46e5] p-2 border-2 border-black text-white">🆔</span>
                                <h2 class="text-2xl font-black uppercase tracking-tight">Identity Data</h2>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-6">
                                <div class="space-y-2">
                                    <label class="block text-xs font-black uppercase tracking-widest text-gray-500">Full Name</label>
                                    <input type="text" value="<%= user ? user.name : '' %>" readonly
                                        class="w-full px-4 py-3 border-2 border-black bg-gray-100 font-bold uppercase text-gray-500 cursor-not-allowed" />
                                </div>
                                <div class="space-y-2">
                                    <label class="block text-xs font-black uppercase tracking-widest text-gray-500">Email Address</label>
                                    <input type="email" value="<%= user ? user.email : '' %>" readonly
                                        class="w-full px-4 py-3 border-2 border-black bg-gray-100 font-bold text-gray-500 cursor-not-allowed" />
                                </div>
                            </div>
                            
                            <% if (user.role === 'mentor' || user.role === 'investor') { %>
                                <div class="grid grid-cols-1 gap-6">
                                    <% if (user.expertise) { %>
                                    <div class="space-y-2">
                                        <label class="block text-xs font-black uppercase tracking-widest text-gray-500">Area of Expertise</label>
                                        <input type="text" value="<%= user.expertise %>" readonly
                                            class="w-full px-4 py-3 border-2 border-black bg-gray-100 font-bold text-gray-500 cursor-not-allowed" />
                                    </div>
                                    <% } %>
                                    <% if (user.company) { %>
                                    <div class="space-y-2">
                                        <label class="block text-xs font-black uppercase tracking-widest text-gray-500">Associated Company</label>
                                        <input type="text" value="<%= user.company %>" readonly
                                            class="w-full px-4 py-3 border-2 border-black bg-gray-100 font-bold text-gray-500 cursor-not-allowed" />
                                    </div>
                                    <% } %>
                                    <% if (user.bio) { %>
                                    <div class="space-y-2">
                                        <label class="block text-xs font-black uppercase tracking-widest text-gray-500">Professional Bio</label>
                                        <textarea readonly rows="3" class="w-full px-4 py-3 border-2 border-black bg-gray-100 font-medium text-gray-500 cursor-not-allowed resize-none"><%= user.bio %></textarea>
                                    </div>
                                    <% } %>
                                </div>
                            <% } %>
                        </section>

                        <section id="change-password" class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000] text-left">
                            <div class="flex items-center gap-3 mb-8 border-b-4 border-black pb-2 w-fit">
                                <span class="bg-[#0f172a] p-2 border-2 border-black text-white">🔐</span>
                                <h2 class="text-2xl font-black uppercase tracking-tight">Security Access</h2>
                            </div>

                            <form action="/v1/auth/profile/update-password" method="POST" class="space-y-6">
                                <div class="space-y-2">
                                    <label class="block text-xs font-black uppercase tracking-widest text-gray-500">Current Password</label>
                                    <input name="currentPassword" type="password" required placeholder="••••••••"
                                        class="w-full px-4 py-3 border-2 border-black bg-[#FFFDF5] font-bold focus:outline-none focus:bg-white focus:shadow-[4px_4px_0_0_#000] transition-all" />
                                </div>

                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                                    <div class="space-y-2">
                                        <label class="block text-xs font-black uppercase tracking-widest text-gray-500">New Password</label>
                                        <input name="newPassword" type="password" required placeholder="••••••••"
                                            class="w-full px-4 py-3 border-2 border-black bg-[#FFFDF5] font-bold focus:outline-none focus:bg-white focus:shadow-[4px_4px_0_0_#000] transition-all" />
                                    </div>
                                    <div class="space-y-2">
                                        <label class="block text-xs font-black uppercase tracking-widest text-gray-500">Confirm New</label>
                                        <input name="confirmPassword" type="password" required placeholder="••••••••"
                                            class="w-full px-4 py-3 border-2 border-black bg-[#FFFDF5] font-bold focus:outline-none focus:bg-white focus:shadow-[4px_4px_0_0_#000] transition-all" />
                                    </div>
                                </div>

                                <button type="submit" class="bg-black text-white px-10 py-4 font-black uppercase border-2 border-black shadow-[4px_4px_0_0_#f59e0b] hover:translate-x-1 hover:translate-y-1 hover:shadow-none transition-all">
                                    Update Credentials
                                </button>
                            </form>
                        </section>

                    <% } else if (dashboard.activeTab === 'projects') { %>
                        <!-- PROJECTS LIST TAB -->
                        <section class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000] text-left">
                            <div class="flex items-center justify-between gap-4 mb-8 border-b-4 border-black pb-4">
                                <div class="flex items-center gap-3">
                                    <span class="bg-[#4f46e5] p-2 border-2 border-black text-white">🚀</span>
                                    <h2 class="text-2xl font-black uppercase tracking-tight">Assigned Projects</h2>
                                </div>
                                <% if (user.role === 'entrepreneur') { %>
                                    <a href="/v1/projects/new" class="bg-brand-amber border-2 border-black px-4 py-2 text-xs font-black uppercase shadow-[3px_3px_0_0_#000] hover:translate-y-0.5 hover:shadow-[1px_1px_0_0_#000] transition-all">
                                        + New Project
                                    </a>
                                <% } %>
                            </div>

                            <% if (dashboard.projects && dashboard.projects.length > 0) { %>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <% dashboard.projects.forEach(project => { %>
                                        <div class="bg-white border-4 border-black p-6 shadow-[4px_4px_0_0_#000] hover:-translate-y-1 transition-all flex flex-col justify-between">
                                            <div>
                                                <div class="flex justify-between items-start gap-2 mb-2">
                                                    <h3 class="text-xl font-black uppercase break-words"><%= project.name %></h3>
                                                    <span class="text-[10px] font-black bg-brand-indigo text-white px-2 py-0.5 border-2 border-black uppercase"><%= project.stage %></span>
                                                </div>
                                                <p class="text-slate-400 font-semibold text-xs mb-3 uppercase"><%= project.domain %></p>
                                                <p class="text-slate-700 text-sm font-medium line-clamp-2 italic mb-4">"<%= project.short_description %>"</p>
                                            </div>
                                            <div class="pt-4 border-t-2 border-slate-100 flex justify-between items-center">
                                                <span class="text-xs font-black uppercase text-slate-500">Status: <%= project.status %></span>
                                                <a href="/v1/projects/<%= project.id %>" class="text-brand-indigo text-xs font-black uppercase hover:underline">
                                                    View Details →
                                                </a>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="text-center py-12">
                                    <div class="text-6xl mb-4 grayscale">📭</div>
                                    <h3 class="text-xl font-black uppercase text-slate-700">No Projects Found</h3>
                                    <p class="text-slate-500 font-medium text-sm mt-1">There are no projects linked to this profile.</p>
                                </div>
                            <% } %>
                        </section>

                    <% } else if (dashboard.activeTab === 'funding') { %>
                        <!-- FUNDING TAB -->
                        <section class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000] text-left">
                            <div class="flex items-center justify-between gap-4 mb-8 border-b-4 border-black pb-4">
                                <div class="flex items-center gap-3">
                                    <span class="bg-green-600 p-2 border-2 border-black text-white">💵</span>
                                    <h2 class="text-2xl font-black uppercase tracking-tight">
                                        <%= user.role === 'investor' ? 'Pending Funding Requests' : 'My Funding Requests' %>
                                    </h2>
                                </div>
                                <% if (user.role === 'entrepreneur') { %>
                                    <a href="/v1/funding/new" class="bg-brand-amber border-2 border-black px-4 py-2 text-xs font-black uppercase shadow-[3px_3px_0_0_#000] hover:translate-y-0.5 hover:shadow-[1px_1px_0_0_#000] transition-all">
                                        + Request Funding
                                    </a>
                                <% } %>
                            </div>

                            <% if (user.role === 'entrepreneur') { %>
                                <!-- Entrepreneur Requests List -->
                                <% if (dashboard.fundingRequests && dashboard.fundingRequests.length > 0) { %>
                                    <div class="space-y-4">
                                        <% dashboard.fundingRequests.forEach(request => { %>
                                            <div class="bg-white border-4 border-black p-6 shadow-[4px_4px_0_0_#000] flex flex-col sm:flex-row justify-between sm:items-center gap-4">
                                                <div>
                                                    <div class="flex items-center gap-3 mb-2 flex-wrap">
                                                        <h3 class="font-black text-lg uppercase"><%= request.project_name %></h3>
                                                        <span class="text-[10px] font-black bg-brand-slate text-white px-2 py-0.5 border-2 border-black uppercase"><%= request.funding_stage %></span>
                                                    </div>
                                                    <% if (request.description) { %>
                                                        <p class="text-slate-600 text-sm font-medium italic mb-2">Usage: <%= request.description %></p>
                                                    <% } %>
                                                    <span class="text-xs text-slate-400 font-bold uppercase">Requested: <%= new Date(request.requested_at).toLocaleDateString('en-US') %></span>
                                                </div>
                                                <div class="flex sm:flex-col items-start sm:items-end justify-between sm:justify-center gap-2">
                                                    <span class="text-xl font-black text-brand-indigo">$<%= parseFloat(request.amount).toLocaleString() %></span>
                                                    <% 
                                                        let badgeBg = 'bg-yellow-100 text-yellow-800 border-yellow-800';
                                                        if (request.status === 'Approved') badgeBg = 'bg-green-100 text-green-800 border-green-800';
                                                        else if (request.status === 'Rejected') badgeBg = 'bg-red-100 text-red-800 border-red-800';
                                                    %>
                                                    <span class="text-[10px] font-black px-2 py-0.5 border-2 uppercase <%= badgeBg %>"><%= request.status %></span>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                <% } else { %>
                                    <div class="text-center py-12">
                                        <div class="text-6xl mb-4">💸</div>
                                        <h3 class="text-xl font-black uppercase text-slate-700">No Funding Requests</h3>
                                        <p class="text-slate-500 font-medium text-sm mt-1">You haven't submitted any funding requests yet.</p>
                                    </div>
                                <% } %>

                            <% } else if (user.role === 'investor') { %>
                                <!-- Investor Pending Requests -->
                                <% if (dashboard.pendingRequests && dashboard.pendingRequests.length > 0) { %>
                                    <div class="space-y-6" id="investorRequests">
                                        <% dashboard.pendingRequests.forEach(request => { %>
                                            <div class="bg-white border-4 border-black p-6 shadow-[4px_4px_0_0_#000] flex flex-col md:flex-row justify-between md:items-center gap-4 relative" id="request-card-<%= request.id %>">
                                                <div class="space-y-2">
                                                    <div class="flex items-center gap-3 flex-wrap">
                                                        <h3 class="font-black text-xl uppercase"><%= request.project_name %></h3>
                                                        <span class="text-xs font-black bg-brand-indigo text-white px-2 py-0.5 border-2 border-black uppercase"><%= request.funding_stage %></span>
                                                    </div>
                                                    <p class="text-slate-500 text-xs font-bold uppercase">Submitted by: <%= request.founder_name || 'Incubator Founder' %></p>
                                                    <p class="text-slate-700 text-sm font-medium italic">"<%= request.description || 'No description provided.' %>"</p>
                                                    <span class="text-xs text-slate-400 font-bold block uppercase">Date: <%= new Date(request.requested_at).toLocaleDateString('en-US', {month: 'short', day: 'numeric', year: 'numeric'}) %></span>
                                                </div>
                                                <div class="flex flex-row md:flex-col items-center md:items-end justify-between md:justify-center gap-3">
                                                    <span class="text-2xl font-black text-green-700">$<%= parseFloat(request.amount).toLocaleString() %></span>
                                                    <div class="flex gap-2">
                                                        <button onclick="updateRequestStatus(<%= request.id %>, 'Approved')" class="bg-green-600 text-white font-black text-xs px-4 py-2 border-2 border-black shadow-[2px_2px_0_0_#000] hover:translate-y-0.5 hover:shadow-none transition-all uppercase">
                                                            Approve
                                                        </button>
                                                        <button onclick="updateRequestStatus(<%= request.id %>, 'Rejected')" class="bg-red-600 text-white font-black text-xs px-4 py-2 border-2 border-black shadow-[2px_2px_0_0_#000] hover:translate-y-0.5 hover:shadow-none transition-all uppercase">
                                                            Reject
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                <% } else { %>
                                    <div class="text-center py-12">
                                        <div class="text-6xl mb-4">🤝</div>
                                        <h3 class="text-xl font-black uppercase text-slate-700">No Pending Requests</h3>
                                        <p class="text-slate-500 font-medium text-sm mt-1">There are no pending funding requests waiting for review.</p>
                                    </div>
                                <% } %>
                            <% } %>
                        </section>

                    <% } else if (dashboard.activeTab === 'portfolio') { %>
                        <!-- INVESTOR PORTFOLIO TAB -->
                        <section class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000] text-left">
                            <div class="flex items-center gap-3 mb-8 border-b-4 border-black pb-4">
                                <span class="bg-green-600 p-2 border-2 border-black text-white">💼</span>
                                <h2 class="text-2xl font-black uppercase tracking-tight">My Portfolio</h2>
                            </div>

                            <% if (dashboard.portfolio && dashboard.portfolio.length > 0) { %>
                                <div class="space-y-4">
                                    <% dashboard.portfolio.forEach(deal => { %>
                                        <div class="bg-white border-4 border-black p-6 shadow-[4px_4px_0_0_#000] flex flex-col sm:flex-row justify-between sm:items-center gap-4">
                                            <div>
                                                <h3 class="font-black text-lg uppercase mb-1"><%= deal.project_name %></h3>
                                                <span class="text-[10px] font-black bg-brand-indigo text-white px-2 py-0.5 border-2 border-black uppercase"><%= deal.funding_stage %></span>
                                                <p class="text-xs text-slate-400 font-bold uppercase mt-2">Funded on: <%= new Date(deal.reviewed_at || deal.updated_at).toLocaleDateString('en-US') %></p>
                                            </div>
                                            <div class="flex sm:flex-col items-start sm:items-end justify-between sm:justify-center gap-2">
                                                <span class="text-2xl font-black text-green-700">$<%= parseFloat(deal.amount).toLocaleString() %></span>
                                                <span class="text-[10px] font-black bg-green-100 text-green-800 border-2 border-green-800 px-2 py-0.5 uppercase">Funded</span>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="text-center py-12">
                                    <div class="text-6xl mb-4 grayscale">💼</div>
                                    <h3 class="text-xl font-black uppercase text-slate-700">No Investments Yet</h3>
                                    <p class="text-slate-500 font-medium text-sm mt-1">Select and approve pending funding requests to build your portfolio.</p>
                                </div>
                            <% } %>
                        </section>

                    <% } else if (dashboard.activeTab === 'workshops') { %>
                        <!-- WORKSHOPS TAB -->
                        <section class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000] text-left">
                            <div class="flex items-center justify-between gap-4 mb-8 border-b-4 border-black pb-4">
                                <div class="flex items-center gap-3">
                                    <span class="bg-[#4f46e5] p-2 border-2 border-black text-white">🎓</span>
                                    <h2 class="text-2xl font-black uppercase tracking-tight">
                                        <%= user.role === 'mentor' ? 'Workshops I Lead' : 'My Enrolled Workshops' %>
                                    </h2>
                                </div>
                                <a href="/v1/workshop" class="bg-brand-amber border-2 border-black px-4 py-2 text-xs font-black uppercase shadow-[3px_3px_0_0_#000] hover:translate-y-0.5 hover:shadow-[1px_1px_0_0_#000] transition-all">
                                    Browse Workshops
                                </a>
                            </div>

                            <% if (dashboard.workshops && dashboard.workshops.length > 0) { %>
                                <div class="space-y-4">
                                    <% dashboard.workshops.forEach(workshop => { %>
                                        <div class="bg-white border-4 border-black p-6 shadow-[4px_4px_0_0_#000] flex flex-col sm:flex-row justify-between sm:items-center gap-4" id="workshop-card-<%= workshop.id %>">
                                            <div>
                                                <h3 class="font-black text-lg uppercase mb-2"><%= workshop.title %></h3>
                                                <div class="space-y-1 mb-2">
                                                    <p class="text-xs text-slate-500 font-bold uppercase">📅 Date: <%= workshop.start_date ? new Date(workshop.start_date).toLocaleDateString('en-US') : 'TBD' %></p>
                                                    <p class="text-xs text-slate-500 font-bold uppercase">📍 Location: <%= workshop.location || 'TBA' %></p>
                                                </div>
                                                <% if (workshop.category) { %>
                                                    <span class="text-[10px] font-black bg-brand-slate text-white px-2 py-0.5 border-2 border-black uppercase"><%= workshop.category %></span>
                                                <% } %>
                                            </div>
                                            <div class="flex sm:flex-col items-start sm:items-end justify-between sm:justify-center gap-3">
                                                <a href="/v1/workshop/<%= workshop.id %>" class="bg-white text-black font-black text-xs px-4 py-2 border-2 border-black hover:bg-slate-50 shadow-[2px_2px_0_0_#000] hover:translate-y-0.5 hover:shadow-none transition-all uppercase">
                                                    Details
                                                </a>
                                                <% if (user.role === 'entrepreneur' && workshop.status !== 'completed') { %>
                                                    <button onclick="cancelEnrollment(<%= workshop.id %>)" class="bg-red-600 text-white font-black text-xs px-4 py-2 border-2 border-black shadow-[2px_2px_0_0_#000] hover:translate-y-0.5 hover:shadow-none transition-all uppercase">
                                                        Cancel
                                                    </button>
                                                <% } else if (workshop.status === 'completed') { %>
                                                    <span class="text-[10px] font-black bg-gray-100 text-gray-800 border-2 border-gray-800 px-2 py-0.5 uppercase">Completed</span>
                                                <% } %>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="text-center py-12">
                                    <div class="text-6xl mb-4 grayscale">🎓</div>
                                    <h3 class="text-xl font-black uppercase text-slate-700">No Workshops</h3>
                                    <p class="text-slate-500 font-medium text-sm mt-1">There are no workshops scheduled on this profile.</p>
                                </div>
                            <% } %>
                        </section>

                    <% } else if (dashboard.activeTab === 'notifications') { %>
                        <!-- NOTIFICATIONS TAB -->
                        <section class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000] text-left">
                            <div class="flex items-center gap-3 mb-8 border-b-4 border-black pb-4">
                                <span class="bg-[#4f46e5] p-2 border-2 border-black text-white">🔔</span>
                                <h2 class="text-2xl font-black uppercase tracking-tight">Notifications</h2>
                            </div>

                            <% if (dashboard.notifications && dashboard.notifications.length > 0) { %>
                                <div class="divide-y-4 divide-black border-4 border-black bg-slate-50">
                                    <% dashboard.notifications.forEach(notification => { %>
                                        <div class="p-6 bg-white flex items-start gap-4 <%= !notification.read ? 'border-l-8 border-brand-indigo' : '' %>">
                                            <div class="text-2xl">
                                                <% if (notification.type === 'funding') { %> 💰
                                                <% } else if (notification.type === 'workshop') { %> 🎓
                                                <% } else if (notification.type === 'project') { %> 🚀
                                                <% } else { %> 📢 <% } %>
                                            </div>
                                            <div class="flex-grow min-w-0">
                                                <p class="font-bold text-sm text-slate-800 leading-normal"><%= notification.message %></p>
                                                <span class="text-[10px] text-slate-400 font-bold block uppercase mt-2"><%= new Date(notification.created_at).toLocaleString('en-US') %></span>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="text-center py-12">
                                    <div class="text-6xl mb-4 grayscale">🔔</div>
                                    <h3 class="text-xl font-black uppercase text-slate-700">All caught up!</h3>
                                    <p class="text-slate-500 font-medium text-sm mt-1">You have no new notifications.</p>
                                </div>
                            <% } %>
                        </section>
                    <% } else if (dashboard.activeTab === 'timeline') { %>
                        <!-- ACTIVITY TIMELINE TAB -->
                        <section class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000] text-left">
                            <div class="flex items-center gap-3 mb-8 border-b-4 border-black pb-4">
                                <span class="bg-[#4f46e5] p-2 border-2 border-black text-white">📜</span>
                                <h2 class="text-2xl font-black uppercase tracking-tight">Activity Timeline</h2>
                            </div>

                            <% if (dashboard.activityLogs && dashboard.activityLogs.length > 0) { %>
                                <div class="relative pl-6 border-l-4 border-black space-y-8">
                                    <% dashboard.activityLogs.forEach((log, index) => { %>
                                        <div class="relative">
                                            <!-- Timeline Dot -->
                                            <div class="absolute -left-[34px] top-1.5 w-4 h-4 bg-black border-4 border-white rounded-full"></div>
                                            
                                            <div class="bg-[#FFFDF5] border-2 border-black p-4 shadow-[3px_3px_0px_0px_#000] relative">
                                                <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
                                                    <span class="bg-black text-white text-[10px] font-black px-2 py-0.5 border-2 border-black uppercase tracking-wider">
                                                        <%= log.action_type %>
                                                    </span>
                                                    <span class="text-[10px] text-slate-400 font-bold block uppercase">
                                                        <%= new Date(log.created_at).toLocaleString('en-US') %>
                                                    </span>
                                                </div>
                                                <p class="font-bold text-sm text-slate-800"><%= log.details %></p>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            <% } else { %>
                                <div class="text-center py-12">
                                    <div class="text-6xl mb-4 grayscale">📜</div>
                                    <h3 class="text-xl font-black uppercase text-slate-700">No activity yet</h3>
                                    <p class="text-slate-500 font-medium text-sm mt-1">Actions you take on the platform will be logged here.</p>
                                </div>
                            <% } %>
                        </section>

                    <% } else if (dashboard.activeTab === 'stats') { %>
                        <!-- PLATFORM STATS TAB -->
                        <section class="bg-white border-4 border-black p-8 shadow-[6px_6px_0px_0px_#000] text-left">
                            <div class="flex items-center gap-3 mb-8 border-b-4 border-black pb-4">
                                <span class="bg-[#f59e0b] p-2 border-2 border-black text-black">📊</span>
                                <h2 class="text-2xl font-black uppercase tracking-tight">Platform Aggregated Stats</h2>
                            </div>

                            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
                                <% 
                                   const metricsMap = {
                                       'total_users': { label: 'Total Members', color: 'bg-brand-indigo', icon: '👥' },
                                       'total_projects': { label: 'Projects Registered', color: 'bg-green-500', icon: '🚀' },
                                       'total_workshops': { label: 'Workshops Conducted', color: 'bg-brand-amber', icon: '🎓' },
                                       'total_funding_requested': { label: 'Funding Requests', color: 'bg-[#ef4444]', icon: '💵' },
                                       'total_funding_approved': { label: 'Approved Fundings', color: 'bg-purple-500', icon: '🏆' }
                                   };
                                %>

                                <% dashboard.stats.forEach(metric => { %>
                                    <% const metadata = metricsMap[metric.metric_key] || { label: metric.metric_key, color: 'bg-blue-500', icon: '⚡' }; %>
                                    <div class="bg-white border-4 border-black p-6 shadow-[4px_4px_0_0_#000] flex flex-col justify-between">
                                        <div class="flex items-center justify-between mb-4">
                                            <span class="text-3xl"><%= metadata.icon %></span>
                                            <span class="<%= metadata.color %> text-white text-[10px] font-black px-2 py-1 border-2 border-black uppercase">
                                                Active
                                            </span>
                                        </div>
                                        <div>
                                            <h3 class="text-xs font-black uppercase text-slate-400 tracking-wider mb-1"><%= metadata.label %></h3>
                                            <span class="text-3xl font-black text-black"><%= metric.metric_value %></span>
                                        </div>
                                        <div class="mt-4 pt-2 border-t-2 border-slate-100">
                                            <span class="text-[9px] text-slate-400 font-bold block uppercase">
                                                Last Sync: <%= new Date(metric.updated_at).toLocaleString() %>
                                            </span>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        </section>
                    <% } %>

                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer.ejs') %>

    <!-- Client side dynamic scripting -->
    <script>
        // Update funding request status (Investor dashboard)
        async function updateRequestStatus(requestId, newStatus) {
            if (!confirm(`Are you sure you want to set this funding request to '${newStatus}'?`)) return;
            
            try {
                const response = await fetch(`/v1/funding/${requestId}/status`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ status: newStatus, notes: `Reviewed by investor.` })
                });
                
                const result = await response.json();
                if (response.ok && result.success) {
                    alert(`Funding request successfully ${newStatus.toLowerCase()}!`);
                    
                    // Remove card or reload page
                    const card = document.getElementById(`request-card-${requestId}`);
                    if (card) {
                        card.style.opacity = '0.5';
                        setTimeout(() => { window.location.reload(); }, 500);
                    } else {
                        window.location.reload();
                    }
                } else {
                    alert(`Error: ${result.message || 'Failed to update request status.'}`);
                }
            } catch (err) {
                console.error('Request status update error:', err);
                alert('An error occurred while updating the status.');
            }
        }

        // Cancel workshop enrollment (Entrepreneur dashboard)
        async function cancelEnrollment(workshopId) {
            if (!confirm('Are you sure you want to cancel your enrollment in this workshop?')) return;
            
            try {
                const response = await fetch(`/v1/workshop/${workshopId}/attend`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });
                
                const result = await response.json();
                if (response.ok) {
                    alert('Workshop enrollment successfully cancelled!');
                    
                    // Remove card or reload page
                    const card = document.getElementById(`workshop-card-${workshopId}`);
                    if (card) {
                        card.style.opacity = '0.5';
                        setTimeout(() => { window.location.reload(); }, 500);
                    } else {
                        window.location.reload();
                    }
                } else {
                    alert(`Error: ${result.message || 'Failed to cancel enrollment.'}`);
                }
            } catch (err) {
                console.error('Cancel enrollment error:', err);
                alert('An error occurred while cancelling your enrollment.');
            }
        }
    </script>
</body>

</html>